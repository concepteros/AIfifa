# ============================================
# AIfifa — AI Football Prediction Bot
# Copy to .env and fill in your keys:
#   cp .env.example .env
# ============================================

# --- Required: The Odds API ---
# Get key: https://the-odds-api.com/#get-access
# Free tier: 500 req/month, h2h + totals + spreads
THE_ODDS_API_KEY=your-key-here

# --- Optional: Predict.fun (on-chain betting) ---
# Get key: https://predict.fun → Account → API Keys
# Required for: live market odds, on-chain bets
PREDICTFUN_API_KEY=your-key-here

# Predict.fun wallet (BNB Chain) — only needed for real-money bets
PREDICTFUN_WALLET_ADDRESS=0x...
PREDICTFUN_WALLET_PRIVATE_KEY=your-private-key

# --- Optional: api-football ---
# Get key: https://www.api-football.com/
# Free tier: 100 req/day, Bet365 odds + lineups
API_FOOTBALL_KEY=your-key-here

# --- Optional: Telegram notifications ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Optional: Sportmonks (mostly unused — 2026 WC not covered) ---
SPORTMONKS_API_KEY=your-key-here

# --- Deprecated ---
PREDICT_API_KEY=deprecated
PREDICT_API_URL=https://api.predict.fun/v1/markets
POLYMARKET_API_URL=https://gamma-api.polymarket.com
SPORTMONKS_API_URL=https://api.sportmonks.com
