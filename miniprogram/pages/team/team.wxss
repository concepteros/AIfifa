.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #e5ece5;
  color: #4c5b52;
  font-size: 25rpx;
}

.player-card {
  padding: 20rpx 0;
  border-top: 1rpx solid #e5ece5;
}

.player-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.player-stats text {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #edf5ef;
  color: #1d6b42;
  font-size: 22rpx;
}
