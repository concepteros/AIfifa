.group-card {
  margin-bottom: 24rpx;
  padding-top: 4rpx;
}

.group-title {
  display: block;
  margin-bottom: 8rpx;
  color: #1d6b42;
  font-size: 30rpx;
  font-weight: 900;
}

.schedule-row {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
  padding: 18rpx 0;
  border-top: 1rpx solid #e5ece5;
}

.schedule-cell,
.score-cell {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.matchup {
  flex: 1.35;
}

.schedule-cell {
  flex: 0.85;
}

.venue {
  flex: 1.1;
}

.score-cell {
  width: 110rpx;
  align-items: center;
  padding: 10rpx;
  border-radius: 12rpx;
  background: #edf5ef;
}

.cell-label {
  color: #6b786f;
  font-size: 20rpx;
  font-weight: 800;
}

.cell-value,
.score-value {
  color: #1c2a22;
  font-size: 23rpx;
  font-weight: 900;
  overflow-wrap: anywhere;
}

.score-value {
  color: #1d6b42;
}
