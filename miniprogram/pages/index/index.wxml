<view class="page">
  <view class="hero">
    <text class="eyebrow">FIFA World Cup 2026</text>
    <text class="hero-title">世界杯数据中心</text>
    <text class="hero-copy">实时胜率、球队资料、赛程日历和球迷预测，一次打开就够。</text>
    <view class="button-row">
      <navigator class="nav-button" url="/pages/groups/groups">小组赛赛程</navigator>
      <navigator class="nav-button" url="/pages/predictions/predictions">你的预测</navigator>
      <navigator class="nav-button" url="/pages/mvp/mvp">MVP 球员</navigator>
      <view class="nav-button" bindtap="refreshLocal">刷新数据</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-head">
      <view>
        <text class="eyebrow">Contenders</text>
        <text class="section-title">夺冠胜率 Top 12</text>
      </view>
      <text class="muted">{{updatedAt}}</text>
    </view>
    <block wx:for="{{topTeams}}" wx:key="code">
      <view class="team-row" bindtap="openTeam" data-code="{{item.code}}">
        <view class="team-main">
          <text class="team-name">{{item.label}}</text>
          <text class="team-meta">{{item.code}} · {{item.confederation}} · {{item.form}}</text>
        </view>
        <text class="probability">{{item.probabilityText}}</text>
      </view>
    </block>
  </view>

  <view class="panel">
    <view class="section-head">
      <view>
        <text class="eyebrow">Teams</text>
        <text class="section-title">48 支参赛队伍</text>
      </view>
    </view>
    <block wx:for="{{teams}}" wx:key="code">
      <view class="team-row" bindtap="openTeam" data-code="{{item.code}}">
        <view class="team-main">
          <text class="team-name">{{item.label}}</text>
          <text class="team-meta">小组 {{item.group}} · {{item.confederation}}</text>
        </view>
        <text class="tag">{{item.code}}</text>
      </view>
    </block>
  </view>
</view>
