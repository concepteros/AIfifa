page {
  min-height: 100%;
  background: #f5f8f4;
  color: #1c2a22;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 28rpx;
}

.hero,
.panel {
  border: 1rpx solid #dfe8df;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(24, 48, 34, 0.06);
}

.hero {
  margin-bottom: 24rpx;
  padding: 34rpx;
  background: #12392a;
  color: #ffffff;
}

.hero-title {
  display: block;
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.18;
}

.hero-copy {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.6;
}

.eyebrow {
  color: #4f8b62;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.panel {
  margin-bottom: 22rpx;
  padding: 26rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.section-title {
  display: block;
  margin-top: 6rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.muted {
  color: #69786f;
  font-size: 24rpx;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.nav-button,
.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 88rpx;
  border-radius: 14rpx;
  background: #eaf4ed;
  color: #12392a;
  font-weight: 900;
}

.nav-button {
  width: calc(50% - 8rpx);
}

.primary-button {
  background: #1d6b42;
  color: #ffffff;
}

.team-row,
.match-row,
.vote-row,
.mvp-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #e5ece5;
}

.team-main {
  min-width: 0;
}

.team-name {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  overflow-wrap: anywhere;
}

.team-meta {
  display: block;
  margin-top: 6rpx;
  color: #6b786f;
  font-size: 22rpx;
}

.probability {
  color: #1d6b42;
  font-weight: 900;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #edf5ef;
  color: #1d6b42;
  font-size: 22rpx;
  font-weight: 900;
}

.empty {
  padding: 36rpx 0;
  color: #69786f;
  text-align: center;
}
